{
  "name": "nexus-crm-pro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "electron:start": "electron .",
    "electron:build": "electron-builder --win"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.469.0",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "@tailwindcss/vite": "^4.1.14",
    "tailwindcss": "^4.1.14",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.adlantic.crmpro",
    "productName": "Adlantic CRM Pro",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "index.html",
      "logo.png",
      "electron-main.cjs",
      "public/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Adlantic CRM Pro"
    }
  }
}
